{
  "name": "mission-board",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev:api": "PORT=3200 bun run src/server.ts",
    "dev:dashboard": "PORT=3201 bun run dashboard/server.ts",
    "build": "tsc",
    "build:cli": "bun build cli/src/index.ts --compile --outfile dist/mission",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'Linting not configured yet'",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.9",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  }
}
